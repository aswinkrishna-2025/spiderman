const SHEET_NAME='Registrations';const PAYMENT_FOLDER='Brand New Day Payment Proofs';const KARMA_FOLDER='Brand New Day MuLearn Proofs';
const HEADERS=['Timestamp','Team Name','College','Member 1 Name','Member 1 Phone','Member 1 Email','Member 1 Department','Member 1 Year','Member 2 Name','Member 2 Phone','Member 2 Email','Member 2 Department','Member 2 Year','Transaction ID','Payment Screenshot URL','Payment Status','Entry Status','Remarks','Member 1 MuLearn Karma','Member 1 MuLearn ID','Member 2 MuLearn Karma','Member 2 MuLearn ID','Registration Fee','MuLearn Dashboard Proof URL'];
function doPost(e){try{const d=JSON.parse(e.postData.contents);if(d.action==='list'||d.action==='update')return admin(d);return register(d)}catch(err){return out({success:false,error:String(err.message||err)})}}
function upload(folderName,b64,mime,name){if(!b64)return '';const fs=DriveApp.getFoldersByName(folderName);const folder=fs.hasNext()?fs.next():DriveApp.createFolder(folderName);const file=folder.createFile(Utilities.newBlob(Utilities.base64Decode(b64),mime,name));file.setSharing(DriveApp.Access.ANYONE_WITH_LINK,DriveApp.Permission.VIEW);return file.getUrl()}
function register(d){const s=sheet();const names=s.getLastRow()>1?s.getRange(2,2,s.getLastRow()-1,1).getValues().flat().map(String):[];if(names.some(n=>n.toLowerCase()===String(d.teamName).toLowerCase()))throw new Error('This team name is already registered.');const fee=Number(d.registrationFee);const qualified=(Number(d.m1Karma)>=10?1:0)+(Number(d.m2Karma)>=10?1:0);const correctFee=qualified===2?0:qualified===1?20:40;if(fee!==correctFee)throw new Error('Entry fee does not match μLearn karma eligibility.');const paymentUrl=upload(PAYMENT_FOLDER,d.fileData,d.mimeType,`${d.teamName}-${d.fileName||'payment'}`);const karmaUrl=upload(KARMA_FOLDER,d.karmaFileData,d.karmaMimeType,`${d.teamName}-${d.karmaFileName||'mulearn-dashboard'}`);if(fee>0&&!paymentUrl)throw new Error('Payment proof is required.');if(fee<40&&!karmaUrl)throw new Error('μLearn dashboard proof is required.');s.appendRow([new Date(),d.teamName,d.college,d.m1Name,d.m1Phone,d.m1Email,d.m1Department,d.m1Year,d.m2Name,d.m2Phone,d.m2Email,d.m2Department,d.m2Year,d.transactionId||'',paymentUrl,fee===0?'MuLearn Verification':'Pending','Not Entered','',d.m1Karma,d.m1MuId,d.m2Karma,d.m2MuId,fee,karmaUrl]);return out({success:true})}
function admin(d){const expected=PropertiesService.getScriptProperties().getProperty('ADMIN_SECRET');if(!expected||d.adminSecret!==expected)throw new Error('Unauthorized');const s=sheet();if(d.action==='update'){const cols={paymentStatus:16,entryStatus:17,remarks:18};if(!cols[d.field]||Number(d.row)<2)throw new Error('Invalid update');s.getRange(Number(d.row),cols[d.field]).setValue(String(d.value));return out({success:true})}const values=s.getLastRow()>1?s.getRange(2,1,s.getLastRow()-1,24).getDisplayValues():[];const rows=values.map((v,i)=>({row:i+2,timestamp:v[0],teamName:v[1],college:v[2],m1Name:v[3],m1Phone:v[4],m1Email:v[5],m1Department:v[6],m1Year:v[7],m2Name:v[8],m2Phone:v[9],m2Email:v[10],m2Department:v[11],m2Year:v[12],transactionId:v[13],screenshotUrl:v[14],paymentStatus:v[15],entryStatus:v[16]||'Not Entered',remarks:v[17],m1Karma:v[18],m1MuId:v[19],m2Karma:v[20],m2MuId:v[21],registrationFee:v[22],karmaProofUrl:v[23]}));return out({success:true,rows})}
function sheet(){const ss=SpreadsheetApp.getActiveSpreadsheet();let s=ss.getSheetByName(SHEET_NAME);if(!s)s=ss.insertSheet(SHEET_NAME);if(s.getLastRow()===0)s.appendRow(HEADERS);else if(s.getLastColumn()<HEADERS.length)s.getRange(1,1,1,HEADERS.length).setValues([HEADERS]);return s}
function out(v){return ContentService.createTextOutput(JSON.stringify(v)).setMimeType(ContentService.MimeType.JSON)}
